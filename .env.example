# Access Control Middleware - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials - use HashiCorp Vault in production

# ========== Application Configuration ==========

# Application environment (development, testing, production)
APP_ENV=development

# Application name (for logging and identification)
APP_NAME=AccessControlMiddleware

# Application secret key for session management (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
APP_SECRET_KEY=your-secret-key-here-change-in-production

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ========== Database Configuration (SQLite or PostgreSQL) ==========
# 
# The middleware supports BOTH SQLite (encrypted) and PostgreSQL for production use.
# Choose ONE database type by setting DATABASE_TYPE and configuring appropriate variables.
#
# SQLite with SQLCipher: 
#    - Full database encryption (AES-256)
#    - Production-ready with WAL mode for concurrent access
#    - Ideal for: Edge deployments, self-contained instances, development
#    - Performance: <1% overhead, startup ~1-2 seconds
#
# PostgreSQL with SSL/TLS:
#    - Server-side encryption + TLS connection encryption
#    - Production-ready for high-concurrency deployments
#    - Ideal for: Distributed systems, high-availability, cloud deployments
#    - Performance: Connection pooling recommended

# ===== CHOOSE DATABASE TYPE (sqlite or postgresql) =====
DATABASE_TYPE=sqlite

# ===== SQLite Configuration (when DATABASE_TYPE=sqlite) =====
# Path to encrypted SQLite database file using SQLCipher
# File will be created automatically if it doesn't exist
DB_PATH=./data/access_control.db

# SQLCipher encryption passphrase (REQUIRED for SQLite)
# Requirements:
#   - Minimum: 16 characters (enforced by application)
#   - Recommended: 32+ characters, strong entropy
#   - CRITICAL: Store in environment or secure vault, never in version control
#   - Rotate: Update Vault secret, restart application
# Generate strong passphrase: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSPHRASE=your-32-character-minimum-secure-passphrase-here

# SQLCipher key derivation iterations (optional, default: 64000)
# Higher iterations = more secure but slower startup (PBKDF2)
# Trade-off: 64000 = ~1-2 seconds startup time (recommended for production)
# Range: 1000-256000 iterations
# DB_KDF_ITER=64000

# ===== PostgreSQL Configuration (when DATABASE_TYPE=postgresql) =====
# PostgreSQL database name (REQUIRED for PostgreSQL)
# POSTGRES_DB=access_control

# PostgreSQL username (REQUIRED for PostgreSQL)
# POSTGRES_USER=app_user

# PostgreSQL password (REQUIRED for PostgreSQL)
# IMPORTANT: Store in Vault for production, NOT in .env
# POSTGRES_PASSWORD=your-secure-postgres-password-here

# PostgreSQL host/hostname (default: localhost)
# POSTGRES_HOST=db.example.com

# PostgreSQL port (default: 5432)
# POSTGRES_PORT=5432

# PostgreSQL SSL/TLS mode (default: require)
# Options:
#   - disable: No encryption (DON'T use in production)
#   - allow: Encryption if available (development only)
#   - prefer: Try encryption, fallback to unencrypted (testing)
#   - require: Encryption mandatory, fail if unavailable (RECOMMENDED for production)
#   - verify-ca: Verify CA certificate (HIGH SECURITY)
#   - verify-full: Verify CA + hostname (MAXIMUM SECURITY)
# POSTGRES_SSL_MODE=require

# ===== Connection & Performance =====
# Connection pool settings (applies to all databases)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Enable SQL logging (set to true for debugging, false for production)
DATABASE_ECHO=false

# ========== Device Integration Configuration ==========

# Device mode: mock (for testing), isapi (Hikvision production)
# mock = Simulated devices for development and testing
# isapi = Live Hikvision devices via ISAPI protocol
DEVICE_MODE=mock

# Device connection timeout (seconds)
DEVICE_CONNECT_TIMEOUT=10

# Device read/write timeout (seconds)
DEVICE_IO_TIMEOUT=30

# Maximum concurrent device connections
MAX_DEVICE_CONNECTIONS=50

# ========== Authentication & Security ==========

# HashiCorp Vault configuration
# Vault server address (http://localhost:8200 for local development)
VAULT_URL=http://localhost:8200

# Vault authentication token
# Generate with: vault token create -display-name=acm-app -ttl=8760h
VAULT_TOKEN=your-vault-token-here

# Vault secret path prefix (where middleware credentials are stored)
# Default: secret/data/access-control
VAULT_SECRET_PATH=secret/data/access-control

# Vault TLS settings (disable for development, enable for production)
VAULT_SKIP_VERIFY=false

# Enable HTTPS for produced APIs (set to true in production)
API_USE_HTTPS=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== Cache Configuration (Redis) ==========

# Redis connection URL for caching and message queuing
# Format: redis://username:password@hostname:port/db
# Default SQLite cache: sqlite+aiosqlite:///./cache.db
REDIS_URL=redis://localhost:6379/0

# Redis connection pool size
REDIS_POOL_SIZE=10

# Cache TTL in seconds (3600 = 1 hour)
CACHE_TTL=3600

# ========== Event Processing ==========

# Event queue backend (redis, memory for testing)
EVENT_QUEUE_BACKEND=redis

# Event batch size for processing
EVENT_BATCH_SIZE=100

# Event retention period in days
EVENT_RETENTION_DAYS=90

# ========== Network Configuration ==========

# Application port
APP_PORT=8000

# Application host
APP_HOST=0.0.0.0

# Number of worker processes (uvicorn)
WORKERS=4

# ========== External Services ==========

# DuckDNS configuration (optional - for dynamic DNS)
DUCKDNS_DOMAIN=your-duckdns-domain.duckdns.org
DUCKDNS_TOKEN=your-duckdns-token

# SMTP configuration for notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@access-control-middleware.local

# ========== Monitoring & Observability ==========

# Application Insights instrumentation key (Azure monitoring)
APPINSIGHTS_INSTRUMENTATION_KEY=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable debug mode (set to false in production)
DEBUG=true

# ========== Deployment Mode ==========

# Docker Compose environment
# Set to "docker" when running in Docker, "local" for local development
ENVIRONMENT=local

# ========== API & Feature Flags ==========

# Enable Swagger UI documentation
SWAGGER_ENABLED=true

# Enable device health checks
HEALTH_CHECK_ENABLED=true

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=300

# ========== Testing Configuration ==========

# Test database URL (can be different from production)
TEST_DATABASE_URL=sqlite:///./test_access_control.db

# Enable test fixtures
FIXTURES_ENABLED=true

# ========== Legacy/Optional Configuration ==========

# Project root directory (auto-detected if not set)
# PROJECT_ROOT=/path/to/project

# Migrations directory (relative to PROJECT_ROOT)
# MIGRATIONS_DIR=migrations

# Logs directory
# LOGS_DIR=logs
